{
  "name": "tunnelfs-remote",
  "displayName": "TunnelFS Remote",
  "description": "Remote component for TunnelFS — serves filesystem via WebDAV over the tunnel",
  "version": "0.0.2",
  "publisher": "twilightcoders",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TwilightCoders/vscode-tunnelfs"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "TunnelFS",
      "properties": {
        "tunnelfs.root": {
          "type": "string",
          "default": "",
          "description": "Root directory to serve. Defaults to the user's home directory."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "package": "npm run compile -- --minify",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
